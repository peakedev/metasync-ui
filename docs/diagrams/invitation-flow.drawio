    <!-- Step 9 notes -->
    <mxCell id="s9-note" value="9. Read invitation_id from user.user_metadata&#xa;   SELECT * FROM invitations WHERE id = invitation_id&#xa;       AND status = 'pending' AND expires_at &gt; now()&#xa;   INSERT INTO tenant_memberships (tenant_id, user_id, role, client_id)&#xa;   UPDATE invitations SET status = 'accepted'" style="rounded=1;fillColor=#fff9c4;strokeColor=#d6b656;align=left;" vertex="1" parent="1">
