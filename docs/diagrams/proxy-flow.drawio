    <!-- Step 1: Browser → Edge Function -->
    <mxCell id="s1" value="1. POST /proxy  {tenantId, path, method, body}  Authorization: Bearer JWT" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1">
